{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/augentic/specify/schemas/skill.schema.json",
  "title": "SKILL.md frontmatter",
  "description": "Validates the YAML frontmatter of a Specify skill definition file.",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Skill identifier, must match directory name."
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "One-line description including when to use the skill."
    },
    "license": {
      "type": "string",
      "enum": ["MIT", "Apache-2.0", "proprietary"],
      "description": "License identifier."
    },
    "argument-hint": {
      "type": "string",
      "description": "Argument pattern using [required] [optional?] syntax."
    },
    "allowed-tools": {
      "type": "string",
      "description": "Comma-separated tool names."
    }
  }
}
